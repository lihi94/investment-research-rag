# Copy this file to ".env" and fill in the real values.
# The .env file is gitignored and must never be committed.

# --- Supabase ---
# Found in: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://knggijdnvyswmzffrmlr.supabase.co
# The "service_role" / "secret" key. Bypasses RLS. KEEP PRIVATE.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- OpenAI (embeddings) ---
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Anthropic (Claude for answering questions) ---
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Local paths ---
# Directory containing the PDF books to ingest.
PDF_DIR=./data/pdfs
# Where to write ingestion logs.
LOG_DIR=./logs

# --- Model choices (defaults are fine to start) ---
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=claude-sonnet-4-6

# --- Chunking parameters ---
# Approximate words per chunk (500-800 is a sensible range).
CHUNK_WORDS=650
# Word overlap between consecutive chunks (helps avoid losing context at boundaries).
CHUNK_OVERLAP_WORDS=80
